{
  "name": "sara-szpak",
  "version": "1.0.0",
  "private": true,
  "description": "Sara Szpak Website",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:app\"",
    "dev:css": "sass scss/main.scss public/css/style.css --watch",
    "dev:app": "node scripts/dev-server.js",
    "dev:serve": "live-server public --port=5500 --watch=public --quiet",
    "build:css": "sass scss/main.scss public/css/style.css --no-source-map",
    "build": "npm run build:css",
    "start": "echo \"static site\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "live-server": "^1.2.2",
    "sass": "^1.93.2"
  }
}
